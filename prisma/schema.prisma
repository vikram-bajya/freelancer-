// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant workspace (one per freelancer/agency) ───────────────────────
model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  brandColor  String   @default("#6366f1")
  customDomain String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users    User[]
  clients  Client[]
  projects Project[]
  invoices Invoice[]
}

// ─── NextAuth required tables ─────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users (freelancers / team members) ───────────────────────────────────────
model User {
  id          String    @id @default(cuid())
  name        String?
  email       String    @unique
  emailVerified DateTime?
  password    String?
  image       String?
  role        String    @default("OWNER") // OWNER | MEMBER
  workspaceId String?
  createdAt   DateTime  @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  accounts  Account[]
  sessions  Session[]
  messages  Message[]
}

// ─── Clients (portal users, passwordless magic-link access) ───────────────────
model Client {
  id          String   @id @default(cuid())
  name        String
  email       String
  workspaceId String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  projects  Project[]

  @@unique([email, workspaceId])
}

// ─── Projects ─────────────────────────────────────────────────────────────────
model Project {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("ACTIVE") // ACTIVE | REVIEW | COMPLETED | PAUSED
  dueDate     DateTime?
  workspaceId String
  clientId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id])
  client         Client          @relation(fields: [clientId], references: [id])
  files          ProjectFile[]
  approvals      ApprovalItem[]
  invoices       Invoice[]
  messages       Message[]
  timelineEvents TimelineEvent[]
}

// ─── Files & Deliverables ─────────────────────────────────────────────────────
model ProjectFile {
  id        String   @id @default(cuid())
  projectId String
  name      String
  url       String
  size      Int?
  type      String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Approval Items ───────────────────────────────────────────────────────────
model ApprovalItem {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      String   @default("PENDING") // PENDING | APPROVED | REVISION
  clientNote  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Invoices ─────────────────────────────────────────────────────────────────
model Invoice {
  id               String    @id @default(cuid())
  workspaceId      String
  projectId        String
  amount           Float
  currency         String    @default("USD")
  status           String    @default("DRAFT") // DRAFT | SENT | PAID | OVERDUE
  dueDate          DateTime?
  stripePaymentUrl String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])
}

// ─── Messages (threaded per project) ──────────────────────────────────────────
model Message {
  id        String   @id @default(cuid())
  projectId String
  senderId  String
  senderName String
  senderType String   @default("FREELANCER") // FREELANCER | CLIENT
  body      String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [senderId], references: [id])
}

// ─── Timeline Events ──────────────────────────────────────────────────────────
model TimelineEvent {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  date        DateTime
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
